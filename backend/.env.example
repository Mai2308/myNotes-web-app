# Environment Configuration Template for Notes App Backend

# Server Configuration
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/notes-app
# or for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/notes-app?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

# Email Service Configuration (for sending reminders and notifications)
# Using Gmail:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# OR Using other email services:
# For SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

# For AWS SES:
# SMTP_HOST=email-smtp.region.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=your-ses-username
# SMTP_PASS=your-ses-password

# For Office365:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your-email@outlook.com
# SMTP_PASS=your-password

# Reminder/Notification Settings
# Scheduler check interval in milliseconds (default: 60000 = 1 minute)
REMINDER_CHECK_INTERVAL=60000

# Cleanup old notifications older than X days (default: 30)
NOTIFICATION_CLEANUP_DAYS=30

# Application URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:5000

# Optional: Admin Settings
ADMIN_EMAIL=admin@example.com

# Optional: Feature Flags
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_REMINDERS=true
ENABLE_RECURRING_REMINDERS=true
